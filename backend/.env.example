# Supabase Configuration (Required)
# Note: The backend requires the SERVICE_ROLE_KEY to bypass RLS, not the anon key.
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Optional: Supabase Anon Key (Currently not used by backend, but often kept in .env)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Local LLM Configuration (Optional)
OLLAMA_HOST=http://localhost:11434

# CORS Configuration (Optional, defaults to standard local dev ports)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://localhost:4173
